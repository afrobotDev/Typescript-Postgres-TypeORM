{
  "name": "typescript-postgres-typeorm",
  "version": "1.0.0",
  "description": "A project to practice building REST APIs",
  "scripts": {
    "dev": "nodemon --watch src --exec \"tsx --no-warnings --env-file=.env\" ./src/index.ts",
    "start": "tsx --no-warnings --env-file=.env ./src/index.ts",
    "typeorm": "tsx ./node_modules/typeorm/cli.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.3.0",
    "morgan": "^1.11.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
